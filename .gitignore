# Python byte-compiled / optimised / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
.venv/
venv/
env/
ENV/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# Jupyter notebook checkpoints
.ipynb_checkpoints/

# Raw data — do not commit large data files
data/raw/*.csv
data/raw/*.xlsx
data/raw/*.json
data/raw/*.parquet

# Processed data — cleaned outputs (re-generated by pipeline)
data/processed/*.csv
data/processed/*.parquet

# Report figures (regenerated by notebook)
reports/figures/*.png
reports/figures/*.svg
reports/figures/*.pdf

# OS artefacts
.DS_Store
Thumbs.db

# Editor / IDE
.idea/
.vscode/
*.swp
*.swo

# Pytest cache
.pytest_cache/

# Coverage
.coverage
htmlcov/
